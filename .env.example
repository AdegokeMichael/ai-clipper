# ─────────────────────────────────────────────────────
#  AI Clipper — Environment Config
#  Copy to .env and fill in your keys
#  Run: python setup_check.py to verify
# ─────────────────────────────────────────────────────

# ── Anthropic (required) ──────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── App Config ────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Whisper Model ─────────────────────────────────────
# Options: tiny | base | small | medium | large-v3
WHISPER_MODEL=base

# ── Clip Config ───────────────────────────────────────
MAX_CLIP_DURATION=90
MIN_CLIP_DURATION=30

# ── Watch Folder (optional) ───────────────────────────
# Without Docker: WATCH_FOLDER=./watch_inbox
# With Docker:    WATCH_FOLDER=/app/watch_inbox
# WATCH_FOLDER=./watch_inbox

# ═══════════════════════════════════════════════════
#  PLATFORMS — add credentials for each you want to use
# ═══════════════════════════════════════════════════

# ── YouTube Shorts (easiest — instant setup) ──────────
# 1. console.cloud.google.com → Enable YouTube Data API v3
# 2. Create OAuth 2.0 credentials (Desktop app type)
# 3. Download client_secret JSON → set path below
# 4. Run: python cli.py youtube-auth  (one-time browser login)
YOUTUBE_CLIENT_SECRETS_FILE=./client_secret.json
YOUTUBE_TOKEN_FILE=./youtube_token.json
# YOUTUBE_CHANNEL_ID=UCxxxxxxx  (optional, for logging)

# ── Instagram Reels ───────────────────────────────────
# 1. Facebook Business account required
# 2. developers.facebook.com → Create app → Instagram Graph API
# 3. Get long-lived Page Access Token
# 4. Find your Instagram Business Account ID
# INSTAGRAM_ACCESS_TOKEN=your_token_here
# INSTAGRAM_ACCOUNT_ID=your_account_id_here
# INSTAGRAM_PUBLIC_BASE_URL=http://135.236.211.197:8000

# ── Facebook Reels ────────────────────────────────────
# Same Meta developer app as Instagram
# 1. Get long-lived Page Access Token
# 2. Find your Facebook Page ID
# FACEBOOK_ACCESS_TOKEN=your_token_here
# FACEBOOK_PAGE_ID=your_page_id_here
# FACEBOOK_PUBLIC_BASE_URL=http://135.236.211.197:8000

# ── TikTok (pending API review — 2-3 business days) ───
# 1. developers.tiktok.com → Create app → Content Posting API
# 2. Complete business verification
# 3. Get access token via OAuth
# TIKTOK_ACCESS_TOKEN=your_token_here
# TIKTOK_CLIENT_KEY=your_client_key
# TIKTOK_CLIENT_SECRET=your_client_secret

# ── Scheduler defaults ────────────────────────────────
# Configurable via the dashboard Settings tab
# SCHEDULE_ENABLED=false
# SCHEDULE_DAILY_LIMIT=3
# SCHEDULE_TIMES=08:00,13:00,19:00

# ── Brand Outro Template ──────────────────────────────
# Configurable via the dashboard Settings tab
# OVERLAY_ENABLED=true
# OVERLAY_TEMPLATE=overlays/template.png
# OVERLAY_DURATION=4       # seconds to show the brand card
# OVERLAY_FADE=true        # fade in/out transition

# ═══════════════════════════════════════════════════
#  AI PROVIDER — choose your model brain
#  Options: claude | groq | ollama
# ═══════════════════════════════════════════════════

AI_PROVIDER=groq        # switch here, nothing else changes

# ── Claude (best quality, paid) ───────────────────
# ANTHROPIC_API_KEY already set above
# CLAUDE_MODEL=claude-haiku-4-5-20251001   # cheaper option
# CLAUDE_MODEL=claude-sonnet-4-20250514    # higher quality

# ── Groq (free, fast, recommended) ───────────────
# Get free API key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile      # default, best quality
# GROQ_MODEL=llama-3.1-8b-instant         # faster, lighter

# ── Ollama (free forever, runs locally) ──────────
# Install: https://ollama.ai
# Pull model: ollama pull llama3.2
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# ── Google Drive Sync (service account — never expires) ──────────────────────
# Full setup guide at top of scripts/gdrive_watch.py
#
# 1. Google Cloud → IAM → Service Accounts → Create → Download JSON key
# 2. Enable Google Drive API in Google Cloud Console
# 3. Share your Drive folder with the service account email (Editor access)
# 4. Get folder ID from the Drive URL
#
# GDRIVE_SERVICE_ACCOUNT_FILE=./gdrive_service_account.json
# GDRIVE_FOLDER_ID=your_folder_id_from_drive_url
# GDRIVE_SYNC_INTERVAL=30
# WATCH_FOLDER=/home/ubuntu/ai-autoposting-agent/gdrive_inbox

# ── Upload-Post (post to TikTok/Instagram/Facebook without API approval) ────────
# 1. Create account at https://upload-post.com (free tier: 10 uploads/month)
# 2. Connect your TikTok, Instagram, Facebook accounts in their dashboard
# 3. Copy your API key from dashboard → API Keys
# 4. Note your profile name (used when connecting accounts)
# 5. Verify: GET http://YOUR_SERVER:8000/uploadpost/verify
#
# UPLOADPOST_API_KEY=your_api_key_here
# UPLOADPOST_PROFILE=your_profile_name_here
